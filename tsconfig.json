// six-js\tsconfig.json
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "strict": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "rootDir": "./src",
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "src/properties",
    "src/styles",
    "src/jsx.d.ts",
    "src/core/breakpoints.ts",
    "src/core/inertia-physics.ts",
    "src/core/observer.ts",
    "src/core/safe-element.ts",
    "src/core/time.ts"
  ]
}